# OneTeam configuration. `install.sh` copies this to `.env` and fills the generated secrets on
# first run. Set ZITADEL_DOMAIN to a name that resolves to this box (required for Caddy to issue
# a public TLS cert).

# --- pinned versions ---
ZITADEL_VERSION=v4.15.3
POSTGRES_IMAGE=postgres:17

# --- public endpoint ---
ZITADEL_DOMAIN=id.example.com
ZITADEL_EXTERNALPORT=443
ZITADEL_EXTERNALSECURE=true

# --- secrets (generated by install.sh; leave blank to auto-fill) ---
# ZITADEL_MASTERKEY must be EXACTLY 32 chars and can never change after init.
ZITADEL_MASTERKEY=
POSTGRES_PASSWORD=
ZITADEL_PG_PASSWORD=
PORTAL_PG_PASSWORD=
