# OneTeam configuration.
#
# `install.sh` copies this file to `.env` on first run and fills every blank secret with a random
# value. The ONLY thing you must set by hand is ZITADEL_DOMAIN (below). Never hand-edit the secrets,
# and never commit `.env` — it is gitignored.

# --- pinned image versions (bump deliberately; Zitadel migrates its DB on upgrade) ---
ZITADEL_VERSION=v4.15.3
POSTGRES_IMAGE=postgres:17

# --- public endpoint ---------------------------------------------------------------
# ZITADEL_DOMAIN — the hostname your identity provider answers on.
#   * Use a SUBDOMAIN (e.g. id.yourcompany.com), NOT the bare apex — keep the apex for a landing
#     page and (later) your email domain.
#   * It MUST resolve to this box (an A record) BEFORE you run install.sh — Caddy validates it live
#     to issue the TLS cert. On Cloudflare, set the record to DNS-only (grey cloud), not proxied.
#   * FROZEN AT FIRST INIT: baked into Zitadel's issuer URLs / cookies / tokens. Changing it later
#     means wiping and reinitializing Zitadel. Pick the one you'll keep.
ZITADEL_DOMAIN=id.example.com
ZITADEL_EXTERNALPORT=443
ZITADEL_EXTERNALSECURE=true

# --- secrets: leave BLANK ----------------------------------------------------------
# install.sh generates each of these once and never overwrites an existing value. Do not set them
# by hand. Back up your .env after first run.
#   ZITADEL_MASTERKEY is exactly 32 chars, encrypts data at rest, and is ALSO frozen after init —
#   change or lose it and the encrypted data is unrecoverable.
ZITADEL_MASTERKEY=
POSTGRES_PASSWORD=
ZITADEL_PG_PASSWORD=
PORTAL_PG_PASSWORD=
